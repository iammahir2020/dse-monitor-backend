  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.4",
    "ngrok": "^5.0.0-beta.2",
    "nodemon": "^3.1.14",
    "telegraf": "^4.16.3",
    "ws": "^8.20.0"
  }
