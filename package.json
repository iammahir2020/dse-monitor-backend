{
  "name": "dse-monitor-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "node scripts/install-python-deps.js",
    "check:node": "node -e \"const major = Number(process.versions.node.split('.')[0]); if (major < 20) { console.error('Node >=20 is required'); process.exit(1); }\"",
    "prebuild": "npm run check:node",
    "build": "find . -name '*.js' -not -path './node_modules/*' -not -path './logs/*' -print0 | xargs -0 -n1 node --check",
    "test": "node tests/run-tests.js",
    "phase12:dry-run": "node scripts/phase12-dry-run.js",
    "phase12:run-cycle": "node scripts/phase12-run-cycle.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "axios": "1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.4",
    "nodemon": "^3.1.14",
    "telegraf": "^4.16.3",
    "ws": "^8.20.0"
  }
}
