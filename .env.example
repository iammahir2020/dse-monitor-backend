# Core
NODE_VERSION=20.20.2
NODE_ENV=development
PORT=5000
MONGODB_URI=
FRONTEND_URL=http://localhost:5173
FRONTEND_WEB_URL=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=5
SMS_PROVIDER=console
EXPOSE_OTP_IN_RESPONSE=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_LINK_EXPIRY_MINUTES=15
BACKEND_PUBLIC_URL=

# Python scraper
PYTHON_BIN=python3
SKIP_PYTHON_DEPS=false

# Script helpers (local/staging)
BACKEND_BASE_URL=http://localhost:5000
TEST_AUTH_TOKEN=

# Phase12 feature flags
PHASE12_ENABLE_HIST_SYNC=true
PHASE12_ENABLE_SIGNAL_MONITOR=true
PHASE12_ENABLE_DEPTH_MONITOR=true
PHASE12_ENABLE_SIGNAL_API=false
PHASE12_ENABLE_DEPTH_API=false
PHASE12_ENABLE_DEPTH_WS_EVENTS=false

# Phase12 symbol scope and thresholds
PHASE12_GLOBAL_SYMBOLS=
DEPTH_PRESSURE_THRESHOLD=3
DEPTH_SNAPSHOT_RETENTION_DAYS=7

# Market window (Asia/Dhaka)
BD_MARKET_TIMEZONE=Asia/Dhaka
BD_MARKET_OPEN=10:00
BD_MARKET_CLOSE=14:30

# Phase12 logging
PHASE12_LOG_ERROR_LIMIT=5
PHASE12_LOG_SAMPLE_RATE=1
PHASE12_LOG_INCLUDE_PAYLOADS=false
